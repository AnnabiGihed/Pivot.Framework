<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageId>Pivot.Framework.Containers.API</PackageId>
    <Version>1.0.0</Version>
    <Description>
      ASP.NET Core API container infrastructure for Pivot.Framework.
